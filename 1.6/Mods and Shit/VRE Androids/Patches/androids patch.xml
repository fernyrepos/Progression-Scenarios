		<value>
			<li Class="ProgressionScenarios.ScenarioExtension">
				<iconPath>ScenarioIcons/Android</iconPath>
			</li>
		</value>
	</Operation>


                <Operation Class="PatchOperationReplace">
                    <xpath>Defs/ScenarioDef[defName="VREA_NewUtopia"]/label</xpath>
                    <value>
                        <label>Awakened Androids</label>
                    </value>
                </Operation>
                <Operation Class="PatchOperationReplace">
                    <xpath>Defs/ScenarioDef[defName="VREA_NewUtopia"]/scenario/summary</xpath>
                    <value>
                        <summary>A new blossoming hideout for awakened androids, but can you sustain it?</summary>
                    </value>
                </Operation>
</Patch>